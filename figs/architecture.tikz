% PDE-Agents — Architecture diagram v4
%
% Routing decisions (all explicit to prevent overlaps):
%
%  warm-start (sim→kg):
%    Manhattan: [xshift=-4mm]sim.south → down to y=6.55 (inter-tier gap)
%    → right to x=5.78 (just left of kg.west) → up into kg.west
%    Departs left-of-centre on sim.south, clear of the sim↔fenics line.
%
%  LLM inference (orch↔llm):
%    Vertical at x=10.25 — gap between KG right-edge (9.2)
%    and Storage left-edge (11.3). Avoids all service nodes.
%    Label placed in the inter-tier gap above the exec box.
%
%  FEniCSx → storage removed from diagram; mentioned in caption instead.
%
\begin{tikzpicture}[
  font=\small,
  >=Latex,
  every node/.style={align=center},
  %─── node styles ──────────────────────────────────────────────────────────
  usrnd/.style={
    draw=orange!60, fill=yellow!18, rounded corners=16pt,
    thick, minimum width=3.6cm, minimum height=0.76cm,
    font=\small\bfseries},
  supnd/.style={
    draw=nodeblue, fill=nodeblue!15, rounded corners=5pt,
    very thick, minimum width=13.4cm, minimum height=0.9cm,
    font=\small\bfseries},
  agentnd/.style 2 args={
    draw=#1!88, fill=#1!10, rounded corners=5pt, thick,
    minimum width=3.4cm, minimum height=1.26cm, font=\small},
  svcnd/.style 2 args={
    draw=#1!78, fill=#1!8, rounded corners=4pt, thick,
    minimum width=3.4cm, minimum height=1.15cm, font=\small},
  storend/.style={
    draw=nodegray!60, fill=nodegray!7, rounded corners=4pt, thick,
    minimum width=3.4cm, minimum height=1.05cm, font=\small},
  llmnd/.style={
    draw=nodeblue!58, fill=nodeblue!7, rounded corners=5pt, very thick,
    minimum width=14.0cm, minimum height=1.05cm, font=\footnotesize},
  %─── background boxes ─────────────────────────────────────────────────────
  lbox/.style={
    draw=#1!42, fill=#1!4, rounded corners=8pt, thick, dashed,
    inner sep=0.42cm},
  %─── arrow styles ─────────────────────────────────────────────────────────
  arr/.style   ={->,    thick,      color=#1},
  biarr/.style ={<->,   thick,      color=#1},
  darr/.style  ={->,    thick, dashed, color=#1},
  kgwarm/.style={->,    very thick, dashed, color=nodered!92},
]

%══════════════════════════════════════════════════════════════════════════════
%  NODES  (columns: x = 2.0 / 7.5 / 13.0)
%══════════════════════════════════════════════════════════════════════════════

\node[usrnd] (user) at (7.5, 12.4)
  {User \quad / \quad Natural Language Task};

\node[supnd] (sup) at (7.5, 10.6)
  {LangGraph Supervisor
   \quad {\normalfont\footnotesize llama3.3:70b
   \enspace·\enspace router + synthesiser}};

\node[agentnd={nodegreen}{}]  (sim)  at ( 2.0, 8.2)
  {\textbf{Simulation Agent}\\[2pt]
   {\footnotesize qwen2.5-coder:32b}\\
   {\tiny KG Smart warm-start}};

\node[agentnd={nodeorange}{}] (anal) at ( 7.5, 8.2)
  {\textbf{Analytics Agent}\\[2pt]
   {\footnotesize llama3.3:70b}\\
   {\tiny compare · suggest}};

\node[agentnd={nodeblue}{}]   (dba)  at (13.0, 8.2)
  {\textbf{Database Agent}\\[2pt]
   {\footnotesize qwen2.5-coder:14b}\\
   {\tiny store · catalog · query}};

\begin{scope}[on background layer]
  \node[lbox=nodeblue, fit=(sup)(sim)(anal)(dba)] (orch) {};
\end{scope}
\node[font=\scriptsize\bfseries, text=nodeblue!68,
      anchor=north west, inner sep=3pt] at (orch.north west)
  {Multi-Agent Orchestration \textrm{(LangGraph)}};

%─── Tier 2 — Execution & Knowledge ──────────────────────────────────────────

\node[svcnd={nodegreen}{}] (fenics) at (2.0, 5.0)
  {\textbf{FEniCSx Runner}\\[2pt]
   {\footnotesize DOLFINx 0.10.0.post2}\\
   {\tiny 2D/3D FEM · Gmsh · PETSc · :8080}};

\node[svcnd={nodered}{}]   (kg)     at (7.5, 5.0)
  {\textbf{Neo4j Knowledge Graph}\\[2pt]
   {\footnotesize GraphRAG + HNSW}\\
   {\tiny Materials · Runs · ReferenceChunks}};

\node[storend]             (storage) at (13.0, 5.0)
  {\textbf{Data Storage}\\[2pt]
   {\footnotesize PostgreSQL \enspace·\enspace MinIO}\\
   {\tiny Metadata · VTK · HDF5}};

\begin{scope}[on background layer]
  \node[lbox=nodegray, fit=(fenics)(kg)(storage)] (exec) {};
\end{scope}
\node[font=\scriptsize\bfseries, text=nodegray!72,
      anchor=north west, inner sep=3pt] at (exec.north west)
  {Execution \& Knowledge Layer};

%─── Tier 3 — LLM Backend ─────────────────────────────────────────────────

\node[llmnd] (ollama) at (7.5, 2.2)
  {\textbf{Ollama} \enspace :11434 \enspace·\enspace
   2× RTX PRO 6000 Blackwell \enspace·\enspace CUDA 13.1
   \enspace·\enspace 196\,GB VRAM\\[3pt]
   {\small
    qwen2.5-coder:32b \enspace$|$\enspace
    llama3.3:70b \enspace$|$\enspace
    qwen2.5-coder:14b \enspace$|$\enspace
    nomic-embed-text\;(768-d)}};

\begin{scope}[on background layer]
  \node[draw=nodeblue!40, fill=nodeblue!4, rounded corners=8pt,
        thick, dashed, inner sep=0.30cm, fit=(ollama)] (llmbox) {};
\end{scope}
\node[font=\scriptsize\bfseries, text=nodeblue!62,
      anchor=north west, inner sep=3pt] at (llmbox.north west)
  {LLM Backend};

%══════════════════════════════════════════════════════════════════════════════
%  ARROWS — explicit routes
%══════════════════════════════════════════════════════════════════════════════

%── User ↔ Supervisor  (parallel vertical pair, ±4 mm offset) ────────────────
\draw[arr=black]
  ([xshift= 4mm]user.south) -- ([xshift= 4mm]sup.north)
  node[midway, right=3pt, font=\scriptsize]{task};
\draw[darr=nodegray!75]
  ([xshift=-4mm]sup.north) -- ([xshift=-4mm]user.south)
  node[midway, left=3pt, font=\scriptsize]{response};

%── Supervisor ↔ Agents ───────────────────────────────────────────────────────
\draw[biarr=nodegreen!80]
  (sup.south) to[out=242, in=88]
  node[pos=0.38, left=2pt, font=\tiny]{route/result}
  (sim.north);
\draw[biarr=nodeorange!80]
  (sup.south) -- (anal.north)
  node[midway, right=2pt, font=\tiny]{route/result};
\draw[biarr=nodeblue!80]
  (sup.south) to[out=298, in=92]
  node[pos=0.38, right=2pt, font=\tiny]{route/result}
  (dba.north);

%── Simulation Agent ↔ FEniCSx  (straight vertical) ─────────────────────────
%  Label at pos=0.15 keeps it high inside the orch box bottom margin,
%  well above the warm-start horizontal line at y=6.55.
\draw[biarr=nodegreen!82]
  (sim.south) -- (fenics.north)
  node[pos=0.15, right=2pt, font=\tiny]{config/result};

%── Simulation Agent → KG  (warm-start)
%   Manhattan route:
%     1. Depart 4 mm left of sim.south (avoids overlapping the sim↔fenics line)
%     2. Drop DOWN through the inter-tier gap to y = 6.55
%     3. Go RIGHT to x = 7.00  (5 mm left of kg.north centre at x=7.5)
%     4. Drop DOWN into kg.north from above
%   This keeps the label in the open horizontal corridor and enters KG
%   from the top, clearly distinct from the Analytics→kg.north arrow (x=7.5).
\coordinate (wsA) at (1.60, 6.55);   % inter-tier gap, below sim[-4mm]
\coordinate (wsB) at (7.00, 6.55);   % horizontal run end — 5 mm left of kg.north
\draw[kgwarm]
  ([xshift=-4mm]sim.south)
  -- (wsA)
  -- (wsB)
  node[pos=0.38, above=2pt, font=\tiny]{warm-start query}
  -- ([xshift=-5mm]kg.north);

%── Analytics Agent → KG  (vertical) ─────────────────────────────────────────
\draw[darr=nodered!72]
  (anal.south) -- (kg.north)
  node[midway, right=2pt, font=\tiny]{KG query};

%── Database Agent → Data Storage  (vertical) ────────────────────────────────
\draw[arr=nodegray!78]
  (dba.south) -- (storage.north)
  node[midway, right=2pt, font=\tiny]{store};

%── Orchestration Layer ↔ LLM Backend
%   Vertical at x = 10.25 — sits in the gap between KG right-edge (9.2)
%   and Storage left-edge (11.3), so no node is crossed.
%   Label placed in the inter-tier gap (y ≈ 6.8) well above all service nodes.
\draw[biarr=nodeblue!70]
  ([xshift=2.75cm]orch.south) -- ([xshift=2.75cm]llmbox.north)
  node[pos=0.07, right=4pt, font=\scriptsize]{LLM inference};

%══════════════════════════════════════════════════════════════════════════════
%  LEGEND  — horizontal bar below the LLM Backend, fully outside all boxes
%══════════════════════════════════════════════════════════════════════════════
\draw[draw=gray!40, fill=white, rounded corners=4pt]
  (1.0, 0.55) rectangle (14.0, -0.82);

\node[font=\scriptsize\bfseries] at (7.5, 0.36) {Legend};

%── Row 1
\draw[biarr=nodegray!72]   (1.4,  0.00) -- (2.3,  0.00);
\node[font=\scriptsize, anchor=west] at (2.45, 0.00) {bidirectional flow};

\draw[arr=nodegray!80]     (5.8,  0.00) -- (6.7,  0.00);
\node[font=\scriptsize, anchor=west] at (6.85, 0.00) {data flow / store};

\draw[darr=nodegray!72]    (10.2, 0.00) -- (11.1, 0.00);
\node[font=\scriptsize, anchor=west] at (11.25,0.00) {async / response};

%── Row 2
\draw[kgwarm]              (1.4, -0.47) -- (2.3, -0.47);
\node[font=\scriptsize, anchor=west] at (2.45,-0.47) {KG warm-start (init)};

\draw[darr=nodered!72]     (5.8, -0.47) -- (6.7, -0.47);
\node[font=\scriptsize, anchor=west] at (6.85,-0.47) {KG query (lazy)};

\end{tikzpicture}
